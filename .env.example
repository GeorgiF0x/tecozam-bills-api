# ─── Microsoft SQL Server ────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=tecozam_bills
MSSQL_USER=sa
MSSQL_PASSWORD=

# ─── JWT Authentication ─────────────────────────────────────────
# 256-bit hex string for HS256 signing
JWT_SECRET=
# Access token TTL in milliseconds (default: 15 min)
JWT_EXPIRATION=900000
# Refresh token TTL in milliseconds (default: 7 days)
JWT_REFRESH_EXPIRATION=604800000

# ─── AES Encryption ─────────────────────────────────────────────
# 256-bit hex key for AES-256 field-level encryption
AES_SECRET_KEY=

# ─── SMTP / Email ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@tecozam.com
# Comma-separated list of alert recipients
MAIL_ALERT_RECIPIENTS=admin@tecozam.com

# ─── File Storage ───────────────────────────────────────────────
STORAGE_PATH=/data/tecozam-bills/uploads

# ─── n8n Webhook Integration ────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/tecozam
